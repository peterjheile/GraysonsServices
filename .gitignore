# ==================================================
# Grayson's Services - .gitignore
# Clean, organized, production-ready
# ==================================================


# ==================================================
# Node / Next.js
# ==================================================
node_modules/
.next/
out/
dist/
build/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ==================================================
# Python / Django
# ==================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
*.sqlite3
db.sqlite3

# Virtual Environments
venv/
.venv/



# ==================================================
# Django Specific
# ==================================================
media/
staticfiles/
*.log


# ==================================================
# Environment Variables / Secrets
# ==================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.development
.env.test


# ==================================================
# IDE / Editor
# ==================================================
.vscode/
.idea/
*.swp
*.swo
*.tmp
*.bak


# ==================================================
# OS Generated Files
# ==================================================
.DS_Store
Thumbs.db
desktop.ini


# ==================================================
# Package Managers
# ==================================================
package-lock.json
yarn.lock
pnpm-lock.yaml


# ==================================================
# TypeScript
# ==================================================
*.tsbuildinfo


# ==================================================
# Docker
# ==================================================
*.pid
*.seed
*.pid.lock


# ==================================================
# Misc
# ==================================================
.cache/
.temp/
.tmp/